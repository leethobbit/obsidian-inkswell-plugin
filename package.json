{
  "name": "obsidian-inkswell-plugin",
  "version": "1.9.0",
  "description": "Inkswell — a full writer's suite for Obsidian: projects, compile, goals, sprints, and an invisible-revision decision log.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "build:sample": "npm run build && node scripts/build-sample.mjs",
    "dev-vault:reset": "node scripts/reset-dev-vault.mjs",
    "gen:sample-data": "node scripts/gen-sample-data.mjs",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "lint": "eslint src main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "writing",
    "longform",
    "novel",
    "compile"
  ],
  "author": "Daniel King",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^0.14.0",
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.7.0",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^1.4.0",
    "yaml": "^2.9.0"
  }
}

# build / deps
node_modules/
main.js
*.js.map

# obsidian
data.json

# editor / os
.DS_Store
Thumbs.db
.idea/
*.log

# temp verification harnesses (never committed)
_harness.*

# local, machine-specific agent instructions (AGENTS.md is the committed guide)
CLAUDE.md

# obsidian notes surfaced via junction (DKB owns these)
docs/

# test artifacts
coverage/
.vitest/

# local reference material (third-party workbooks/PDFs) — not for the repo
reference/

# sample vault: commit the seeded writing history (negation must follow the
# global `data.json` ignore above), but never the deployed plugin binaries —
# those are (re)created by `npm run build:sample` (main.js is already ignored).
!examples/sample-vault/.obsidian/plugins/inkswell/data.json
examples/sample-vault/.obsidian/plugins/inkswell/styles.css
examples/sample-vault/.obsidian/plugins/inkswell/manifest.json

# Obsidian UI-layout state churns on every open — keep it out of the committed
# sample vault (the file stays on disk so the vault still opens fine locally).
examples/sample-vault/.obsidian/workspace.json

# Dev scratch vault: a local, throwaway copy of the sample vault for day-to-day
# testing. `npm run dev` deploys here; `npm run dev-vault:reset` re-seeds it from
# the pristine sample vault. Never committed — the committed sample stays clean.
examples/dev-vault/

# internal QA checklists — dev collateral, kept locally, never shipped in the demo
examples/sample-vault/QA.md
examples/sample-vault/QA-lite.md

# internal planning docs (competitor comparisons, feature pick list, roadmap /
# status / QA-gate notes) — kept on disk locally but never committed
FEATURES.md
ROADMAP.md
